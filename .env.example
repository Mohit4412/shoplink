# Optional app URL override for links or deployment-specific configuration.
APP_URL="http://localhost:3000"

# Secret for signing one-click order confirm/decline tokens in WhatsApp messages.
# Generate with: openssl rand -base64 32
ORDER_ACTION_SECRET=""

# Supabase deployment settings. When set, the app uses Supabase Postgres (via REST)
# and Supabase Storage instead of the local SQLite database and public/uploads.
SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_URL=""
SUPABASE_ANON_KEY=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_STORAGE_BUCKET="myshoplink-assets"

# Optional: seed demo analytics/orders for the default demo merchant in Supabase mode.
MYSHOPLINK_ENABLE_DEMO_SEED="false"

# Vercel API — required for custom domain provisioning (Pro feature)
# Get these from: https://vercel.com/account/tokens and your project settings
VERCEL_API_TOKEN=""
VERCEL_PROJECT_ID=""
VERCEL_TEAM_ID=""   # only needed if your project is under a Vercel team

# Razorpay — merchant subscription billing
# Get these from: https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=""
NEXT_PUBLIC_RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
RAZORPAY_PLAN_ID=""          # Subscriptions → Plans → your plan ID
RAZORPAY_WEBHOOK_SECRET=""   # Settings → Webhooks → webhook secret

# Email — required for password reset emails (optional, falls back to console.log in dev)
# Get your API key from: https://resend.com
RESEND_API_KEY=""
RESEND_FROM_EMAIL="noreply@myshoplink.site"

# Dev only: force a specific plan for all users regardless of their actual plan.
# Set to "Free" or "Pro". Remove or leave blank in production.
# NEXT_PUBLIC_DEV_FORCE_PLAN="Free"

# Early access — set to true to grant free Pro trials on signup
# First 100 users get 3 months Pro free, everyone after gets 14 days
EARLY_ACCESS_ENABLED="false"
